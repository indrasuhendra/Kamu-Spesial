<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Untuk Kamu ❤️</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap" rel="stylesheet">

  <style>
    *{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}

    body{
      height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      background: radial-gradient(circle at top, #ff9a9e, #fad0c4);
      overflow:hidden;
    }

    .card{
      background: rgba(255,255,255,0.2);
      backdrop-filter: blur(20px);
      border-radius: 25px;
      padding: 30px;
      text-align:center;
      box-shadow:0 10px 40px rgba(0,0,0,0.3);
    }

    .card img{
      width:130px;height:130px;border-radius:50%;border:4px solid white;margin-bottom:15px;
    }

    h1,p{color:white;}
    p{margin-bottom:20px;}

    button{
      padding:12px 20px;
      border:none;
      border-radius:12px;
      font-size:16px;
      cursor:pointer;
      margin:5px;
      transition:0.2s;
    }

    #yes{background:#4CAF50;color:white;}
    #no{background:#ff4d4d;color:white;position:fixed;}

    .love{position:fixed;top:-10px;color:red;animation:fall linear forwards;}
    @keyframes fall{to{transform:translateY(100vh);opacity:0;}}

    .shake{animation:shake 0.2s;}
    @keyframes shake{
      0%{transform:translate(0)}
      25%{transform:translate(-5px,5px)}
      50%{transform:translate(5px,-5px)}
      75%{transform:translate(-5px,5px)}
      100%{transform:translate(0)}
    }
  </style>
</head>

<body>

<div class="card">
  <img src="https://media.giphy.com/media/MDJ9IbxxvDUQM/giphy.gif">
  <h1>💖 Aku Sayang Kamu, Nikita 💖</h1>
  <p>My Yuu sayang aku juga nggak? 😳</p>

  <button id="yes" onclick="jawabYes()">Iya ❤️</button>
  <button id="no">Tidak 😜</button>
</div>

<audio id="bgm" autoplay loop>
  <source src="https://www.bensound.com/bensound-music/bensound-romantic.mp3">
</audio>

<audio id="sad">
  <source src="https://www.soundjay.com/button/beep-07.wav">
</audio>

<script>
let scale=1,noSize=1,msgIndex=0;
let angle=0;

const messages=["Yakin? 😢","Jangan 😭","Please 🥺","Aku sedih 💔","Klik iya aja 😤"];

const btnNo=document.getElementById('no');
const btnYes=document.getElementById('yes');

// orbit otomatis
setInterval(()=>{
  orbitNo();
},40);

function orbitNo(){
  const card=document.querySelector('.card');
  const rect=card.getBoundingClientRect();

  const centerX=rect.left + rect.width/2;
  const centerY=rect.top + rect.height/2;

  const radius=120; // jarak orbit

  angle += 0.05; // kecepatan muter

  const x=centerX + radius * Math.cos(angle);
  const y=centerY + radius * Math.sin(angle);

  btnNo.style.left = x + 'px';
  btnNo.style.top = y + 'px';

  // efek interaksi saat didekati
  btnNo.onmouseenter = ()=>{
    document.getElementById('sad').play();
    document.body.classList.add('shake');
    setTimeout(()=>document.body.classList.remove('shake'),200);

    scale += 0.3;
    btnYes.style.transform = `scale(${scale})`;

    noSize = Math.max(0.3, noSize - 0.1);
    btnNo.style.transform = `scale(${noSize})`;

    btnNo.innerText = messages[msgIndex++ % messages.length];

    if(scale > 3){
      btnYes.style.position='fixed';
      btnYes.style.top='0';
      btnYes.style.left='0';
      btnYes.style.width='100vw';
      btnYes.style.height='100vh';
      btnYes.style.fontSize='40px';
      btnYes.innerText='IYA SEKARANG 😆❤️';
    }
  }
}

function jawabYes(){
  document.body.innerHTML=`
  <div style="display:flex;justify-content:center;align-items:center;height:100vh;flex-direction:column;color:white;">
    <h1 style="font-size:60px">LOVE YOU NIKITA ❤️🔥</h1>
    <p style="font-size:20px">My Yuu milikku sekarang 😆💘</p>
  </div>`;

  for(let i=0;i<100;i++){
    const c=document.createElement('div');
    c.innerHTML='🎉';
    c.style.position='fixed';
    c.style.left=Math.random()*100+'vw';
    c.style.top=Math.random()*100+'vh';
    c.style.fontSize='20px';
    document.body.appendChild(c);
  }
}

// love jatuh
setInterval(()=>{
  const h=document.createElement('div');
  h.className='love';
  h.innerHTML='❤️';
  h.style.left=Math.random()*100+'vw';
  h.style.animationDuration=(Math.random()*3+2)+'s';
  document.body.appendChild(h);
  setTimeout(()=>h.remove(),5000);
},300);
</script>

</body>
</html>
